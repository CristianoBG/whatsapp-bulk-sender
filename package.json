{
  "name": "whatsapp-bulk-sender",
  "version": "2.1.0",
  "type": "module",
  "description": "Professional WhatsApp Bulk Messaging CLI Tool (Production Grade)",
  "main": "dist/cli/index.js",
  "bin": {
    "whatsapp-bulk": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node dist/cli/index.js",
    "dev": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/cli/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "bulk",
    "messaging",
    "baileys",
    "typescript",
    "cli"
  ],
  "author": "Cristiano/Antigravity",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@inquirer/prompts": "^8.3.2",
    "@whiskeysockets/baileys": "^6.6.0",
    "commander": "^11.1.0",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.5",
    "picocolors": "^1.1.1",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
